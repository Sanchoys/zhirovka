# PostgreSQL database name created by the container.
POSTGRES_DB=zhirovka

# PostgreSQL user used by the backend application.
POSTGRES_USER=zhirovka

# PostgreSQL password. Change this value before running in production.
POSTGRES_PASSWORD=change_me

# PostgreSQL hostname inside the Docker Compose network.
POSTGRES_HOST=db

# PostgreSQL port inside the Docker Compose network.
POSTGRES_PORT=5432

# Host machine port exposed by the FastAPI application.
APP_HOST_PORT=5000
